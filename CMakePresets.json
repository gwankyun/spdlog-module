{
    "version": 10,
    "include": [
        "presets/configure.json"
    ],
    "configurePresets": [
        {
            "name": "common",
            "hidden": true,
            "inherits": [
                "vcpkg-manifest-mode-off",
                "vcpkg-manifest-install-off"
            ]
        },
        {
            "name": "msvc",
            "inherits": [
                "common",
                "msvc-base"
            ]
        },
        {
            "name": "clang",
            "inherits": [
                "common",
                "clang-base"
            ]
        },
        {
            "name": "gcc",
            "inherits": [
                "common",
                "gcc-base"
            ]
        }
    ],
    "buildPresets": [
        {
            "name": "msvc",
            "configurePreset": "msvc",
            "configuration": "Debug"
        },
        {
            "name": "clang",
            "configurePreset": "clang",
            "configuration": "Debug"
        },
        {
            "name": "gcc",
            "configurePreset": "gcc",
            "configuration": "Debug"
        }
    ],
    "workflowPresets": [
        {
            "name": "msvc",
            "steps": [
                {
                    "type": "configure",
                    "name": "msvc"
                },
                {
                    "type": "build",
                    "name": "msvc"
                }
            ]
        },
        {
            "name": "clang",
            "steps": [
                {
                    "type": "configure",
                    "name": "clang"
                },
                {
                    "type": "build",
                    "name": "clang"
                }
            ]
        },
        {
            "name": "gcc",
            "steps": [
                {
                    "type": "configure",
                    "name": "gcc"
                },
                {
                    "type": "build",
                    "name": "gcc"
                }
            ]
        }
    ]
}